# =============================================================
# vera-bot — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================

# ── LLM PROVIDER ──────────────────────────────────────────────
# Choose: anthropic | openai | gemini | deepseek
VERA_LLM_PROVIDER=anthropic

# Your API key for the chosen provider
VERA_LLM_API_KEY=your_api_key_here

# Optional: override the default model for your provider
# Anthropic default: claude-3-5-sonnet-20241022
# OpenAI default:    gpt-4o
# Gemini default:    gemini-1.5-flash
# DeepSeek default:  deepseek-chat
VERA_LLM_MODEL=

# LLM call timeout in seconds (must be < 30s hard limit)
VERA_LLM_TIMEOUT=25

# ── TEAM INFO ─────────────────────────────────────────────────
VERA_TEAM_NAME=Vera AI Bot
VERA_TEAM_MEMBERS=["Kumar Abhishek"]
VERA_CONTACT_EMAIL=kumar@example.com
VERA_BOT_VERSION=1.0.0

# ── BOT TUNING ────────────────────────────────────────────────
# Max actions returned per /v1/tick call (judge cap is 20)
VERA_MAX_ACTIONS_PER_TICK=8

# Max turns per conversation before auto-close
VERA_MAX_CONVERSATION_TURNS=5

# Seconds to wait after detecting auto-reply (4h = 14400)
VERA_AUTO_REPLY_WAIT_SECONDS=14400

# How many consecutive auto-replies before ending the conversation
VERA_AUTO_REPLY_MAX_BEFORE_END=3
